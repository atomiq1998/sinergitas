# PostgreSQL connection string (Neon, Vercel Postgres, Supabase, dll.)
# Contoh Neon: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Wajib di production — ganti dengan string acak yang kuat
JWT_SECRET="sinergitas-jwt-secret-change-in-production"
